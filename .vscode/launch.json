{
    "version": "0.2.0",
    "configurations": [          
        {
      "type": "node",
      "request": "launch",
      "name": "Run ccs-condition-linter",
      "program": "${workspaceFolder}/ccs-condition-linter.js",
      "args": [
        "--condition",
        "$[?(@.documentid == \"ESOTERIC_BILL_IDENTIFIER\" && @.some.nested.value < 0)]",
        "--input",
        "test.json"
      ],
      "console": "integratedTerminal"
    }
    ]
}